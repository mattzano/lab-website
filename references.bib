
@article{zanovello_unexpected_2023,
	title = {Unexpected frequency of the pathogenic \textit{{AR}} {CAG} repeat expansion in the general population},
	volume = {146},
	copyright = {https://creativecommons.org/licenses/by/4.0/},
	issn = {0006-8950, 1460-2156},
	url = {https://academic.oup.com/brain/article/146/7/2723/7043521},
	doi = {10.1093/brain/awad050},
	abstract = {Abstract
            CAG repeat expansions in exon 1 of the AR gene on the X chromosome cause spinal and bulbar muscular atrophy, a male-specific progressive neuromuscular disorder associated with a variety of extra-neurological symptoms. The disease has a reported male prevalence of approximately 1:30 000 or less, but the AR repeat expansion frequency is unknown. We established a pipeline, which combines the use of the ExpansionHunter tool and visual validation, to detect AR CAG expansion on whole-genome sequencing data, benchmarked it to fragment PCR sizing, and applied it to 74 277 unrelated individuals from four large cohorts. Our pipeline showed sensitivity of 100\% [95\% confidence interval (CI) 90.8–100\%], specificity of 99\% (95\% CI 94.2–99.7\%), and a positive predictive value of 97.4\% (95\% CI 84.4–99.6\%). We found the mutation frequency to be 1:3182 (95\% CI 1:2309–1:4386, n = 117 734) X chromosomes—10 times more frequent than the reported disease prevalence. Modelling using the novel mutation frequency led to estimate disease prevalence of 1:6887 males, more than four times more frequent than the reported disease prevalence. This discrepancy is possibly due to underdiagnosis of this neuromuscular condition, reduced penetrance, and/or pleomorphic clinical manifestations.},
	language = {en},
	number = {7},
	urldate = {2024-10-17},
	journal = {Brain},
	author = {Zanovello, Matteo and Ibáñez, Kristina and Brown, Anna-Leigh and Sivakumar, Prasanth and Bombaci, Alessandro and Santos, Liana and Van Vugt, Joke J F A and Narzisi, Giuseppe and Karra, Ramita and Scholz, Sonja W and Ding, Jinhui and Gibbs, J Raphael and Chiò, Adriano and Dalgard, Clifton and Weisburd, Ben and {The American Genome Center (TAGC) consortium, Genomics England Research Consortium, Project MinE ALS Sequencing Consortium, The NYGC ALS Consortium} and Ambrose, John C and Arumugam, Prabhu and Bevers, Roel and Bleda, Marta and Boardman-Pretty, Freya and Boustred, Christopher R and Brittain, Helen and Caulfield, Mark J and Chan, Georgia C and Elgar, Greg and Fowler, Tom and Giess, Adam and Hamblin, Angela and Henderson, Shirley and Hubbard, Tim J P and Jackson, Rob and Jones, Louise J and Kasperaviciute, Dalia and Kayikci, Melis and Kousathanas, Athanasios and Lahnstein, Lea and Leigh, Sarah E A and Leong, Ivonne U S and Lopez, Javier F and Maleady-Crowe, Fiona and McEntagart, Meriel and Minneci, Federico and Moutsianas, Loukas and Mueller, Michael and Murugaesu, Nirupa and Need, Anna C and O’Donovan, Peter and Odhams, Chris A and Patch, Christine and Pereira, Mariana Buongermino and Perez-Gil, Daniel and Pullinger, John and Rahim, Tahrima and Rendon, Augusto and Rogers, Tim and Savage, Kevin and Sawant, Kushmita and Scott, Richard H and Siddiq, Afshan and Sieghart, Alexander and Smith, Samuel C and Sosinsky, Alona and Stuckey, Alexander and Tanguy, Mélanie and Tavares, Ana Lisa Taylor and Thomas, Ellen R A and Thompson, Simon R and Tucci, Arianna and Welland, Matthew J and Williams, Eleanor and Witkowska, Katarzyna and Wood, Suzanne M and Van Rheenen, Wouter and Pulit, Sara L and Dekker, Annelot M and Khleifat, Ahmad Al and Brands, William J and Iacoangeli, Alfredo and Kenna, Kevin P and Kavak, Ersen and Kooyman, Maarten and McLaughlin, Russell L and Middelkoop, Bas and Moisse, Matthieu and Schellevis, Raymond D and Shatunov, Aleksey and Sproviero, William and Tazelaar, Gijs H P and Van Der Spek, Rick A A and Van Doormaal, Perry T C and Van Eijk, Kristel R and Van Vugt, Joke and Basak, A Nazli and Blair, Ian P and Glass, Jonathan D and Hardiman, Orla and Hide, Winston and Landers, John E and Mora, Jesus S and Morrison, Karen E and Newhouse, Stephen and Robberecht, Wim and Shaw, Christopher E and Shaw, Pamela J and Van Damme, Philip and Van Es, Michael A and Wray, Naomi R and Al-Chalabi, Ammar and Van Den Berg, Leonard H and Veldink, Jan H and Hanna, Michael G and Greensmith, Linda and Phatnani, Hemali and Veldink, Jan H and Traynor, Bryan J and Polke, James and Houlden, Henry and Fratta, Pietro and Tucci, Arianna},
	month = jul,
